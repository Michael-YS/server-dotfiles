# ============================================================================
# INTERACTIVE SHELL CHECK
# Non-interactive shells (scp/rsync/ssh host cmd) should exit immediately
# ============================================================================
[[ $- == *i* ]] || return 0


# ============================================================================
# PROFILE DETECTION
# full  -> full interactive experience (oh-my-zsh + p10k)
# low   -> minimal, fast, dependency-free shell (default)
# ============================================================================
: ${DOTFILES_PROFILE:=$(
  [[ -r ~/.config/dotfiles/profile ]] && cat ~/.config/dotfiles/profile || echo "low"
)}

[[ $DOTFILES_PROFILE =~ ^(low|full)$ ]] || DOTFILES_PROFILE="low"


# ============================================================================
# FULL MODE CONFIGURATION
# ============================================================================
if [[ $DOTFILES_PROFILE == "full" ]]; then
  # Path to oh-my-zsh (portable, no hardcoded /root)
  export ZSH="$HOME/.oh-my-zsh"

  # Powerlevel10k instant prompt (must be early, full mode only)
  if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
    source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
  fi

  # oh-my-zsh theme & plugins
  ZSH_THEME="powerlevel10k/powerlevel10k"
  plugins=(git)

  # Load oh-my-zsh exactly once
  source "$ZSH/oh-my-zsh.sh"

  # Load p10k config
  [[ -f ~/.dotfiles/zsh/p10k.zsh ]] && source ~/.dotfiles/zsh/p10k.zsh
fi


# ============================================================================
# LOW MODE CONFIGURATION
# ============================================================================
if [[ $DOTFILES_PROFILE == "low" ]]; then
  # Minimal history setup
  HISTFILE=~/.zsh_history
  HISTSIZE=1000
  SAVEHIST=1000
  setopt histappend
  setopt sharehistory
  setopt incappendhistory

  # Simple, fast prompt
  PROMPT='%n@%m:%~%# '
  RPROMPT=''
fi


# ============================================================================
# COMMON CONFIGURATION (applies to both modes)
# ============================================================================
alias vi=vim

# User-local binaries
export PATH="$PATH:$HOME/.local/bin"

# Tabby / terminal working directory reporting
precmd () {
  echo -n "\x1b]1337;CurrentDir=$(pwd)\x07"
}
