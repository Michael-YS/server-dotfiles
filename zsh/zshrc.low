# ============================================================================
# LOW PROFILE
# Minimal, fast, dependency-free
# ============================================================================

# ---- history ----
HISTFILE=~/.zsh_history
HISTSIZE=1000
SAVEHIST=1000
setopt histappend
setopt sharehistory
setopt incappendhistory

# ---- prompt ----
PROMPT='%n@%m:%~%# '
RPROMPT=''
